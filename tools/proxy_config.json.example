{
  "log_level": "info",
  "proxy": {
    "host": "127.0.0.1",
    "port": 7890,
    "type": "socks5"
  },
  "fake_ip": {
    "enabled": true,
    "cidr": "198.18.0.0/15"
  },
  "timeout": {
    "connect": 5000,
    "send": 5000,
    "recv": 5000
  },
  "proxy_rules": {
    "allowed_ports": [80, 443, 8080, 8443],
    "dns_mode": "direct",
    "ipv6_mode": "proxy",
    "udp_mode": "block"
  },
  "traffic_logging": false,
  "child_injection": true,
  "target_processes": []
}
